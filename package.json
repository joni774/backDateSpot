{
  "name": "datespot-server",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev --filter=api",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @datespot/database exec prisma migrate deploy",
    "db:seed": "pnpm --filter @datespot/database exec prisma db seed",
    "e2e": "node scripts/e2e-verify.mjs",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
