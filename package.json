{
  "name": "datespot-server",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev --filter=api",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @datespot/database exec prisma migrate deploy",
    "db:seed": "pnpm --filter @datespot/database exec prisma db seed",
    "db:init:docker": "docker compose run --rm db-init",
    "docker:dev": "docker compose --profile dev up --build",
    "docker:microservices": "docker compose --profile microservices up --build",
    "e2e": "node ../e2e/api/verify.mjs",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
