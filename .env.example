# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=datespot_dev

# Full connection string used by all services (constructed from the above in docker-compose)
DATABASE_URL="postgresql://postgres:password@localhost:5432/datespot_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-at-least-32-chars-long-secret"

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Gateway / CORS (optional, for web clients) ───────────────────────────────
# CORS_ORIGIN="https://your-web-app.com"

# ─── Google Places (per-venue photos) ─────────────────────────────────────────
# Enable Places API + Place Photos in Google Cloud Console.
GOOGLE_PLACES_API_KEY=""
# Optional fallback if you use one key for Maps + Places:
GOOGLE_MAPS_API_KEY=""
# Optional: absolute API URL for image links (e.g. Cloudflare tunnel URL).
PUBLIC_API_URL=""
