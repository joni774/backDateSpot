# --- Core (validated at startup) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/datespot_dev"
JWT_SECRET="datespot-super-secret-key-change-in-production-min-32-chars"
PORT=3000
NODE_ENV=development
# Origins for web clients (optional; mobile apps do not need CORS). Comma-separated, or * in dev.
CORS_ORIGIN="*"

# --- Cache (PRD 9.2 — planned; local via docker compose) ---
REDIS_URL="redis://localhost:6379"

# --- Email: SendGrid or AWS SES (PRD 9.3 — planned) ---
SENDGRID_API_KEY=""
# AWS SES alternative:
AWS_SES_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
EMAIL_FROM="noreply@datespot.co.il"

# --- Image storage: S3 or Cloudinary (PRD 9.2 — planned) ---
STORAGE_PROVIDER="s3"
AWS_S3_BUCKET=""
AWS_S3_REGION=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Google Maps Platform / Places API (PRD 9.2–9.3 — planned) ---
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACES_API_KEY=""

# --- Planned v2 integrations (PRD 9.3 / 6.2 — not implemented) ---
# FCM_SERVER_KEY=""
# STRIPE_SECRET_KEY=""
# TRANZILA_TERMINAL=""
